# ── Stoat Bot ──────────────────────────────────────────────────────────────────
# Get your token from https://stoat.chat/settings/bots → your bot → Token
STOAT_BOT_TOKEN=your_bot_token_here
# Your bot's Stoat user ID (run !myid in a server with the bot)
STOAT_BOT_ID=your_bot_id_here
# Your own Stoat user ID (gives you admin access over the bot)
BOT_OWNER_ID=your_stoat_user_id_here
# A test channel ID for the startup smoke-test message (optional)
STOAT_TEST_CHANNEL_ID=

# ── Supabase ───────────────────────────────────────────────────────────────────
# Your Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# SERVICE ROLE KEY — backend only, never commit or expose to frontend
# Found at: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ANON / PUBLIC KEY — safe for dashboard frontend with RLS enabled
# Found at: Settings → API → Project API keys → anon
SUPABASE_ANON_KEY=your_anon_key_here

# ── Optional AI services ───────────────────────────────────────────────────────
# Set provider: openai or anthropic in config.yaml → modules → ai_chat → provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Social alerts — platform API credentials ───────────────────────────────────
# Twitch: create an app at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube: enable YouTube Data API v3 at https://console.cloud.google.com
YOUTUBE_API_KEY=

# Twitter/X: requires Basic or higher plan at https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
